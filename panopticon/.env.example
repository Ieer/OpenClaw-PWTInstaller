# Data root for all bind mounts in panopticon/docker-compose.panopticon.yml
#
# Linux / Raspberry Pi example:
# PANOPTICON_DATA_DIR=/mnt/usb/panopticon-data
#
# Windows example (Docker Desktop):
# PANOPTICON_DATA_DIR=E:/panopticon-data
#
# Recommended: keep runtime data outside the git repo
PANOPTICON_DATA_DIR=/mnt/usb/panopticon-data

# Optional explicit override for tools (if not set, they use PANOPTICON_DATA_DIR/workspaces)
# PANOPTICON_WORKSPACES_ROOT=/mnt/usb/panopticon-data/workspaces
