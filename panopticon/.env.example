# Data root for all bind mounts in panopticon/docker-compose.panopticon.yml
#
# Linux / Raspberry Pi example:
# PANOPTICON_DATA_DIR=/mnt/usb/panopticon-data
#
# Windows example (Docker Desktop):
# PANOPTICON_DATA_DIR=E:/panopticon-data
#
# Recommended: keep runtime data outside the git repo
PANOPTICON_DATA_DIR=/mnt/usb/panopticon-data

# Optional explicit override for tools (if not set, they use PANOPTICON_DATA_DIR/workspaces)
# PANOPTICON_WORKSPACES_ROOT=/mnt/usb/panopticon-data/workspaces

# Optional shared USB bind mount for all openclaw-* agent containers.
# If left empty, compose falls back to ./shared-usb under panopticon/.
# Linux example:
# PANOPTICON_USB_HOST_PATH=/mnt/usb/openclaw-shared
# Raspberry Pi example:
# PANOPTICON_USB_HOST_PATH=/media/pi/OPENCLAW/openclaw-shared
# Windows example (Docker Desktop):
# PANOPTICON_USB_HOST_PATH=E:/openclaw-shared
# PANOPTICON_USB_CONTAINER_PATH=/mnt/usb
#
# Recommended convention inside the shared host path:
# <shared-root>/agents/<agent-slug>
PANOPTICON_USB_HOST_PATH=
PANOPTICON_USB_CONTAINER_PATH=/mnt/usb

# Optional raw knowledge source folder for mission-control-api import/scan.
# If left empty, compose falls back to ./mission-control/knowledge-sources under panopticon/.
# Linux example:
# PANOPTICON_KNOWLEDGE_RAW_SOURCES_PATH=/mnt/usb/knowledge-sources
# Raspberry Pi example:
# PANOPTICON_KNOWLEDGE_RAW_SOURCES_PATH=/media/pi/OPENCLAW/knowledge-sources
# Windows example (Docker Desktop):
# PANOPTICON_KNOWLEDGE_RAW_SOURCES_PATH=E:/knowledge-sources
PANOPTICON_KNOWLEDGE_RAW_SOURCES_PATH=
