# Data root for all bind mounts in panopticon/docker-compose.panopticon.yml
#
# Linux / Raspberry Pi example:
# PANOPTICON_DATA_DIR=/mnt/usb/panopticon-data
#
# Windows example (Docker Desktop):
# PANOPTICON_DATA_DIR=E:/panopticon-data
#
# Recommended: keep runtime data outside the git repo
PANOPTICON_DATA_DIR=/mnt/usb/panopticon-data

# Optional explicit override for tools (if not set, they use PANOPTICON_DATA_DIR/workspaces)
# PANOPTICON_WORKSPACES_ROOT=/mnt/usb/panopticon-data/workspaces

# Optional shared USB bind mount for all openclaw-* agent containers.
# Linux / Raspberry Pi example:
# PANOPTICON_USB_HOST_PATH=/media/pi/4A21-0000
# PANOPTICON_USB_CONTAINER_PATH=/mnt/usb
#
# Recommended convention inside the USB root:
# /media/pi/4A21-0000/agents/<agent-slug>
PANOPTICON_USB_HOST_PATH=/media/pi/4A21-0000
PANOPTICON_USB_CONTAINER_PATH=/mnt/usb

# Raw knowledge source folder under USB root (for mission-control-api import/scan)
# Effective host path: ${PANOPTICON_USB_HOST_PATH}/${PANOPTICON_KNOWLEDGE_USB_SUBDIR}
PANOPTICON_KNOWLEDGE_USB_SUBDIR=knowledge-sources
