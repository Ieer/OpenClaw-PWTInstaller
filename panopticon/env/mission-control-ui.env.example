# Mission Control Dash UI
# UI 會透過 service name 連 API（同 compose network）

MISSION_CONTROL_API_URL=http://mission-control-api:9090

# 若 Mission Control API 有啟用 bearer token，填入同一個 token
MISSION_CONTROL_AUTH_TOKEN=

# Chat 內嵌（同域代理）設定

# Host 端口映射的宿主机地址（Open External 链接使用）。默认 127.0.0.1
MISSION_CONTROL_CHAT_HOST=127.0.0.1

# 容器内 openclaw gateway 端口（默认 26216）
MISSION_CONTROL_CHAT_CONTAINER_GATEWAY_PORT=26216

# Authorization 前缀（默认 Bearer）
MISSION_CONTROL_CHAT_AUTH_SCHEME=Bearer

# 已弃用的 UI 内置 chat reverse proxy，默认关闭。
# 正式入口应通过 mission-control-gateway -> mission-control-api 的 /chat/ 同域代理。
MISSION_CONTROL_ENABLE_LEGACY_CHAT_PROXY=0

# 是否在 UI 中暴露 agent 直连地址（188xx）。默认关闭，仅保留同域 /chat/ 入口。
MISSION_CONTROL_ENABLE_DIRECT_AGENT_LINKS=0

# 按 agent 注入的 gateway token 映射（优先级最高）。示例：
# MISSION_CONTROL_CHAT_AGENT_TOKEN_MAP=nox=xxxx,metrics=yyyy,email=zzzz
MISSION_CONTROL_CHAT_AGENT_TOKEN_MAP=
